{
  "name": "@borgiq/cli",
  "version": "0.6.0",
  "description": "Command-line interface for the BorgIQ workflow automation platform",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "borgiq": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BorgIQ/borgiq-cli.git"
  },
  "homepage": "https://github.com/BorgIQ/borgiq-cli#readme",
  "bugs": {
    "url": "https://github.com/BorgIQ/borgiq-cli/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "ulidx": "2.4.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "tsx": "4.22.0",
    "typescript": "6.0.3"
  }
}
